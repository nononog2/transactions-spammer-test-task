          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "rate(http_server_requests_seconds_count{uri=\"/api/v1/transactions\",method=\"POST\",status=\"429\"}[1m])",
          "legendFormat": "429 overloaded",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "HTTP Throughput (POST /transactions)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
