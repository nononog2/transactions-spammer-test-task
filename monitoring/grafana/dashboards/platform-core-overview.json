          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/transactions\",method=\"POST\"}[1m])) by (le)) * 1000",
          "legendFormat": "p99 HTTP POST latency",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Latency (ms)",
      "type": "timeseries"
    },
